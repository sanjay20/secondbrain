generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── CORE ────────────────────────────────────────────────────────────────────

model User {
  id               String   @id @default(cuid())
  clerkId          String   @unique
  email            String   @unique
  name             String?
  imageUrl         String?
  pushSubscription Json?
  timezone         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  habits              Habit[]
  habitLogs           HabitLog[]
  workouts            Workout[]
  goals               Goal[]
  skills              Skill[]
  journals            JournalEntry[]
  reminders           Reminder[]
  aiBriefings         AiBriefing[]
  aiWeeklyReviews     AiWeeklyReview[]
  aiGoalConflict      AiGoalConflict?
  monthlyLifeScores   MonthlyLifeScore[]
  wealthAccounts      WealthAccount[]
  transactions        Transaction[]
  investments         Investment[]
  savingsGoals        SavingsGoal[]
  tasks               Task[]
  timeBlocks          TimeBlock[]
  weeklyReviews       WeeklyReview[]
  calendarConnection  CalendarConnection?
  visionAreas         VisionArea[]
  fiveYearGoals       FiveYearGoal[]
  monthlyGoals        MonthlyGoal[]
  bucketListItems     BucketListItem[]
  coreValues          CoreValue[]
  moodLogs            MoodLog[]
  gratitudeEntries    GratitudeEntry[]
  affirmations        Affirmation[]
  coachConversations  CoachConversation[]
  coachMessages       CoachMessage[]

  @@map("users")
}

// ─── HEALTH MODULE ───────────────────────────────────────────────────────────

model Habit {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  icon        String   @default("✅")
  color       String   @default("#6366f1")
  category    String   @default("general")
  frequency   String   @default("daily")
  targetCount Int      @default(1)
  isActive    Boolean  @default(true)
  streak      Int      @default(0)
  bestStreak  Int      @default(0)
  totalDone   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  logs HabitLog[]

  @@index([userId])
  @@map("habits")
}

model HabitLog {
  id        String   @id @default(cuid())
  habitId   String
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  completed Boolean  @default(true)
  note      String?
  createdAt DateTime @default(now())

  @@unique([habitId, date])
  @@index([userId, date])
  @@map("habit_logs")
}

model Workout {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  duration  Int
  notes     String?
  date      DateTime @db.Date
  createdAt DateTime @default(now())

  @@index([userId, date])
  @@map("workouts")
}

// ─── CAREER MODULE ───────────────────────────────────────────────────────────

model Goal {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  area        String    @default("career")
  category    String    @default("career")
  status      String    @default("active")
  progress    Int       @default(0)
  priority    String    @default("medium")
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  milestones Milestone[]
  skillGoals SkillGoal[]

  @@index([userId])
  @@map("goals")
}

model Milestone {
  id          String    @id @default(cuid())
  goalId      String
  goal        Goal      @relation(fields: [goalId], references: [id], onDelete: Cascade)
  title       String
  completed   Boolean   @default(false)
  completedAt DateTime?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())

  @@index([goalId])
  @@map("milestones")
}

model Skill {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  area        String   @default("career")
  category    String   @default("technical")
  level       Int      @default(1)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  skillGoals SkillGoal[]

  @@unique([userId, name])
  @@index([userId])
  @@map("skills")
}

model SkillGoal {
  id        String   @id @default(cuid())
  skillId   String
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  goalId    String
  goal      Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([skillId, goalId])
  @@index([skillId])
  @@index([goalId])
  @@map("skill_goals")
}

model JournalEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?
  content   String
  category  String   @default("general")
  mood      String?
  tags      String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reminder  Reminder?

  @@index([userId])
  @@map("journal_entries")
}

// ─── REMINDERS ───────────────────────────────────────────────────────────────

model Reminder {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  journalEntryId String       @unique
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  scheduledAt    DateTime
  status         String       @default("pending")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([userId, status, scheduledAt])
  @@map("reminders")
}

// ─── WEALTH ──────────────────────────────────────────────────────────────────

model WealthAccount {
  id                    String    @id @default(cuid())
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                  String
  type                  String
  balancePaise          Int       @default(0)
  institution           String?
  isLiability           Boolean   @default(false)
  originalPrincipalPaise Int?
  interestRateBps       Int?
  emiPaise              Int?
  tenureMonths          Int?
  paidMonths            Int       @default(0)
  creditLimitPaise      Int?
  minimumPaymentPaise   Int?
  isArchived            Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  transactions Transaction[]

  @@index([userId])
  @@map("wealth_accounts")
}

model Transaction {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId   String
  account     WealthAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  type        String
  amountPaise Int
  category    String
  date        DateTime
  note        String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([userId, date])
  @@index([accountId])
  @@map("transactions")
}

model Investment {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name              String
  investmentType    String
  units             Float    @default(1)
  buyPricePaise     Int
  currentPricePaise Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@map("investments")
}

model SavingsGoal {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  targetPaise     Int
  currentPaise    Int       @default(0)
  targetDate      DateTime?
  linkedAccountId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@map("savings_goals")
}

// ─── DAILY WORK ──────────────────────────────────────────────────────────────

model Task {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  notes         String?
  pillar        String?
  status        String    @default("todo")
  priority      String    @default("medium")
  scheduledDate DateTime
  originalDate  DateTime?
  rolledOver    Boolean   @default(false)
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  timeBlocks TimeBlock[]

  @@index([userId, scheduledDate])
  @@map("tasks")
}

model TimeBlock {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId        String?
  task          Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  goalId        String?
  label         String
  startTime     DateTime
  endTime       DateTime
  googleEventId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId, startTime])
  @@map("time_blocks")
}

model WeeklyReview {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStart DateTime
  weekEnd   DateTime
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, weekStart])
  @@index([userId])
  @@map("weekly_reviews")
}

model CalendarConnection {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String   @default("google")
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  scope        String
  calendarId   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("calendar_connections")
}

// ─── VISION ──────────────────────────────────────────────────────────────────

model VisionArea {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  statement String
  emoji     String   @default("✨")
  color     String   @default("#8b5cf6")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("vision_areas")
}

model FiveYearGoal {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pillar     String
  goal       String
  targetYear Int
  progress   Int      @default(0)
  notes      String?
  status     String   @default("active")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  monthlyGoals MonthlyGoal[]

  @@index([userId])
  @@map("five_year_goals")
}

model MonthlyGoal {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  fiveYearGoalId String
  fiveYearGoal   FiveYearGoal @relation(fields: [fiveYearGoalId], references: [id], onDelete: Cascade)
  title          String
  month          String
  status         String       @default("todo")
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([userId])
  @@index([fiveYearGoalId])
  @@map("monthly_goals")
}

model BucketListItem {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  category    String    @default("experience")
  notes       String?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@map("bucket_list_items")
}

model CoreValue {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@map("core_values")
}

// ─── MINDSET MODULE ──────────────────────────────────────────────────────────

model MoodLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  mood      Int
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
  @@map("mood_logs")
}

model GratitudeEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  item      String
  date      DateTime @db.Date
  createdAt DateTime @default(now())

  @@index([userId, date])
  @@map("gratitude_entries")
}

model Affirmation {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  text      String
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("affirmations")
}

// ─── AI ──────────────────────────────────────────────────────────────────────

model AiBriefing {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  content   String
  createdAt DateTime @default(now())

  @@unique([userId, date])
  @@index([userId])
  @@map("ai_briefings")
}

model AiWeeklyReview {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStart DateTime @db.Date
  weekEnd   DateTime @db.Date
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, weekStart])
  @@index([userId])
  @@map("ai_weekly_reviews")
}

// Goal-conflict analysis is not date-bound, so we keep a single row per user.
// The cache is invalidated when the goals change (inputHash) rather than purely
// on time; updatedAt backs a coarse freshness backstop. See the goal-conflict route.
model AiGoalConflict {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   Json
  inputHash String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ai_goal_conflicts")
}

// Monthly Life Score (SB-44): one AI-scored row per user per calendar month.
// content holds { scores: [{ pillar, score, explanation }] }; the per-pillar
// trend vs. the prior month is computed in the route, not stored.
model MonthlyLifeScore {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  year      Int
  month     Int // 1–12
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, year, month])
  @@index([userId])
  @@map("monthly_life_scores")
}

// ─── AI COACH CHAT ───────────────────────────────────────────────────────────

model CoachConversation {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages  CoachMessage[]

  @@index([userId, updatedAt])
  @@map("coach_conversations")
}

model CoachMessage {
  id             String            @id @default(cuid())
  conversationId String
  conversation   CoachConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           String // "user" | "assistant"
  content        String
  createdAt      DateTime          @default(now())

  @@index([conversationId, createdAt])
  @@map("coach_messages")
}
