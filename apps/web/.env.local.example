DATABASE_URL="postgresql://secondbrain:secondbrain@localhost:5432/secondbrain"
REDIS_URL="redis://localhost:6379"

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
CLERK_WEBHOOK_SECRET=whsec_...

ANTHROPIC_API_KEY=sk-ant-...
# AI provider: "gemini" (default), "anthropic", or "groq"
AI_PROVIDER=gemini
GEMINI_API_KEY=...
GROQ_API_KEY=...
# Set to true to use offline mock AI responses (no API calls / key needed)
MOCK_AI=false

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Timezone for midnight rollover (default UTC)
APP_TZ=UTC
# Secret header for the /api/dailywork/rollover endpoint
ROLLOVER_SECRET=change-me-before-production

# Google Calendar OAuth (Daily Work integration)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback
